@model QLPhongGym.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="login-page">
        <div class="card login-card">
            <div class="card-header text-center">
                <div class="login-logo">
                    <i class="bi bi-envelope-fill"></i>
                </div>
                <h3 class="fw-bold">QUÊN MẬT KHẨU</h3>
                <p class="text-muted">Nhập email để nhận OTP</p>
            </div>

            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="ForgotPassword" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="Nhập email của bạn" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-2">
                        <i class="bi bi-send-fill"></i> Gửi OTP
                    </button>

                    <a asp-action="Login" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                    </a>
                </form>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>