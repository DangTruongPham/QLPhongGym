@model QLPhongGym.Models.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Dashboard quản lý phòng GYM</h2>
        <p class="text-muted mb-0">Tổng quan hoạt động phòng gym theo thời gian thực</p>
    </div>
</div>

<div id="gymCarousel" class="carousel slide mb-4 shadow rounded-4 overflow-hidden" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active hero-slide">
            <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=1400&auto=format&fit=crop" class="d-block w-100" alt="Gym 1">
            <div class="carousel-caption d-none d-md-block">
                <div class="hero-caption">
                    <h3>Quản lý phòng gym chuyên nghiệp</h3>
                    <p>Theo dõi hội viên, check-in, thanh toán và báo cáo dễ dàng.</p>
                </div>
            </div>
        </div>
        <div class="carousel-item hero-slide">
            <img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=1400&auto=format&fit=crop" class="d-block w-100" alt="Gym 2">
            <div class="carousel-caption d-none d-md-block">
                <div class="hero-caption">
                    <h3>Dashboard trực quan</h3>
                    <p>Biểu đồ, báo cáo và thống kê rõ ràng hơn cho quản lý.</p>
                </div>
            </div>
        </div>
        <div class="carousel-item hero-slide">
            <img src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?auto=format&fit=crop&w=1600&q=80" class="d-block w-100" alt="Gym 3">
            <div class="carousel-caption d-none d-md-block">
                <div class="hero-caption">
                    <h3>Hệ thống chuyên nghiệp</h3>
                    <p>Hỗ trợ quản lý hội viên, gói tập, doanh thu và check-in toàn diện.</p>
                </div>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#gymCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#gymCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card card-dashboard border-0 shadow-lg rounded-4 bg-primary text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase small">Tổng hội viên</div>
                        <h2 class="fw-bold">@Model.TongHoiVien</h2>
                    </div>
                    <i class="bi bi-people-fill fs-1 opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card card-dashboard border-0 shadow-lg rounded-4 bg-success text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase small">Tổng gói tập</div>
                        <h2 class="fw-bold">@Model.TongGoiTap</h2>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card card-dashboard border-0 shadow-lg rounded-4 bg-warning text-dark h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase small">Tổng HLV</div>
                        <h2 class="fw-bold">@Model.TongHuanLuyenVien</h2>
                    </div>
                    <i class="bi bi-person-badge-fill fs-1 opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card card-dashboard border-0 shadow-lg rounded-4 bg-danger text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase small">Doanh thu tháng</div>
                        <h2 class="fw-bold">@Model.DoanhThuThangNay.ToString("N0")</h2>
                    </div>
                    <i class="bi bi-cash-coin fs-1 opacity-75"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-lg-8 mb-4">
        <div class="card shadow-lg border-0 rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0">Biểu đồ doanh thu 6 tháng gần nhất</h5>
            </div>
            <div class="card-body px-4 pb-4">
                <canvas id="revenueChart" height="110"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card shadow-lg border-0 rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0">Tình trạng hội viên</h5>
            </div>
            <div class="card-body px-4 pb-4">
                <canvas id="memberStatusChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-lg-6 mb-4">
        <div class="card shadow-lg border-0 rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0">Check-in 7 ngày gần nhất</h5>
            </div>
            <div class="card-body px-4 pb-4">
                <canvas id="checkinChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card shadow-lg border-0 rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0">Thống kê nhanh</h5>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="text-muted small">Tổng đăng ký</div>
                            <div class="fw-bold fs-4">@Model.TongDangKy</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="text-muted small">Check-in hôm nay</div>
                            <div class="fw-bold fs-4">@Model.TongCheckInHomNay</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="text-muted small">Còn hạn</div>
                            <div class="fw-bold fs-4 text-success">@Model.HoiVienConHan</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="text-muted small">Hết hạn</div>
                            <div class="fw-bold fs-4 text-danger">@Model.HoiVienHetHan</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card shadow-lg border-0 rounded-4 h-100">
            <div class="card-header bg-warning-subtle border-0 pt-4 px-4">
                <strong>Hội viên sắp hết hạn</strong>
            </div>
            <div class="card-body px-4 pb-4">
                @if (Model.DangKySapHetHan.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Hội viên</th>
                                    <th>Gói tập</th>
                                    <th>Ngày hết hạn</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.DangKySapHetHan)
                                {
                                    <tr>
                                        <td>@item.HoiVien?.HoTen</td>
                                        <td>@item.GoiTap?.TenGoiTap</td>
                                        <td>@item.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">Không có hội viên nào sắp hết hạn.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card shadow-lg border-0 rounded-4 h-100">
            <div class="card-header bg-info-subtle border-0 pt-4 px-4">
                <strong>Check-in gần đây</strong>
            </div>
            <div class="card-body px-4 pb-4">
                @if (Model.CheckInGanDay.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Hội viên</th>
                                    <th>Thời gian</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CheckInGanDay)
                                {
                                    <tr>
                                        <td>@item.HoiVien?.HoTen</td>
                                        <td>@item.ThoiGianCheckIn.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">Chưa có lịch sử check-in.</p>
                }
            </div>
        </div>
    </div>
</div>

<script>
    const revenueLabels = @Html.Raw(JsonSerializer.Serialize(Model.RevenueLabels));
    const revenueData = @Html.Raw(JsonSerializer.Serialize(Model.RevenueData));

    const checkInLabels = @Html.Raw(JsonSerializer.Serialize(Model.CheckInLabels));
    const checkInData = @Html.Raw(JsonSerializer.Serialize(Model.CheckInData));

    new Chart(document.getElementById('revenueChart'), {
        type: 'bar',
        data: {
            labels: revenueLabels,
            datasets: [{
                label: 'Doanh thu',
                data: revenueData,
                backgroundColor: [
                    '#0d6efd',
                    '#198754',
                    '#ffc107',
                    '#dc3545',
                    '#6f42c1',
                    '#20c997'
                ],
                borderRadius: 10
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false }
            }
        }
    });

    new Chart(document.getElementById('memberStatusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Còn hạn', 'Hết hạn'],
            datasets: [{
                data: [@Model.HoiVienConHan, @Model.HoiVienHetHan],
                backgroundColor: ['#198754', '#dc3545']
            }]
        },
        options: {
            responsive: true
        }
    });

    new Chart(document.getElementById('checkinChart'), {
        type: 'line',
        data: {
            labels: checkInLabels,
            datasets: [{
                label: 'Lượt check-in',
                data: checkInData,
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13,110,253,0.15)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true
        }
    });
</script>