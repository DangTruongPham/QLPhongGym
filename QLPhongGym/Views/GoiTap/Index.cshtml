@model List<QLPhongGym.Models.GoiTap>

@{
    ViewData["Title"] = "Danh sách gói tập";
}

<h2 class="mb-4">Danh sách gói tập</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" asp-action="Index" class="d-flex">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control me-2" placeholder="Nhập tên gói tập..." />
            <button type="submit" class="btn btn-primary">Tìm</button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">+ Thêm gói tập</a>
    </div>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Mã gói</th>
            <th>Tên gói tập</th>
            <th>Thời hạn (tháng)</th>
            <th>Giá tiền</th>
            <th>Mô tả</th>
            <th width="250">Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaGoiTap</td>
                    <td>@item.TenGoiTap</td>
                    <td>@item.ThoiHanThang</td>
                    <td>@item.GiaTien.ToString("N0") VNĐ</td>
                    <td>@item.MoTa</td>
                    <td>
                        <partial name="_ActionButtons"
                                 model='new QLPhongGym.Models.ActionButtonsViewModel { Id = item.MaGoiTap, ControllerName = "GoiTap" }' />
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Không có dữ liệu gói tập</td>
            </tr>
        }
    </tbody>
</table>