@model List<QLPhongGym.Models.DangKyGoiTap>

@{
    ViewData["Title"] = "Đăng ký gói tập";
}

<h2 class="mb-4">Danh sách đăng ký gói tập</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" asp-action="Index" class="d-flex">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control me-2" placeholder="Nhập tên hội viên..." />
            <button type="submit" class="btn btn-primary">Tìm</button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">+ Thêm đăng ký</a>
    </div>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Mã ĐK</th>
            <th>Hội viên</th>
            <th>Gói tập</th>
            <th>Huấn luyện viên</th>
            <th>Ngày bắt đầu</th>
            <th>Ngày kết thúc</th>
            <th>Trạng thái</th>
            <th width="250">Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaDangKy</td>
                    <td>@item.HoiVien?.HoTen</td>
                    <td>@item.GoiTap?.TenGoiTap</td>
                    <td>@item.HuanLuyenVien?.HoTen</td>
                    <td>@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                    <td>@item.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                    <td>@item.TrangThai</td>
                    <td>
                       <partial name="_ActionButtons"
                                model='new QLPhongGym.Models.ActionButtonsViewModel { Id = item.MaDangKy, ControllerName = "DangKyGoiTap" }' />
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center text-muted">Không có dữ liệu đăng ký</td>
            </tr>
        }
    </tbody>
</table>