@model QLPhongGym.Models.ThanhToan

@{
    ViewData["Title"] = "Chi tiết thanh toán";
}

<div class="card shadow border-0 rounded-4">
    <div class="card-header bg-primary text-white py-3 rounded-top-4">
        <h4 class="mb-0">
            <i class="bi bi-receipt-cutoff"></i> Chi tiết thanh toán
        </h4>
    </div>

    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <tr>
                    <th width="220" class="bg-light">Mã thanh toán</th>
                    <td>@Model.MaThanhToan</td>
                </tr>
                <tr>
                    <th class="bg-light">Hội viên</th>
                    <td>@Model.DangKyGoiTap?.HoiVien?.HoTen</td>
                </tr>
                <tr>
                    <th class="bg-light">Gói tập</th>
                    <td>@Model.DangKyGoiTap?.GoiTap?.TenGoiTap</td>
                </tr>
                <tr>
                    <th class="bg-light">Ngày thanh toán</th>
                    <td>@Model.NgayThanhToan.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
                <tr>
                    <th class="bg-light">Số tiền</th>
                    <td class="text-success fw-bold">@Model.SoTien.ToString("N0") VNĐ</td>
                </tr>
                <tr>
                    <th class="bg-light">Phương thức</th>
                    <td>@Model.PhuongThuc</td>
                </tr>
                <tr>
                    <th class="bg-light">Ghi chú</th>
                    <td>@Model.GhiChu</td>
                </tr>
            </table>
        </div>

        @if (Model.PhuongThuc == "Chuyển khoản" && !string.IsNullOrEmpty(Model.VietQrUrl))
        {
            <div class="card shadow-sm border-0 rounded-4 mt-4">
                <div class="card-header bg-info text-white rounded-top-4">
                    <strong><i class="bi bi-qr-code"></i> QR thanh toán</strong>
                </div>
                <div class="card-body text-center">
                    <img src="@Model.VietQrUrl" alt="VietQR" class="img-fluid rounded-3 border mb-3" style="max-width:320px;" />
                    <div>
                        <div><strong>Ngân hàng:</strong> BIDV</div>
                        <div><strong>Số tài khoản:</strong> 7411256649</div>
                        <div><strong>Chủ tài khoản:</strong> PHAM DANG TRUONG</div>
                        <div><strong>Số tiền:</strong> @Model.SoTien.ToString("N0") VNĐ</div>
                        <div><strong>Nội dung:</strong> GYM TT @Model.MaDangKy</div>
                    </div>
                </div>
            </div>
        }

        <div class="mt-4">
            <a asp-action="Edit" asp-route-id="@Model.MaThanhToan" class="btn btn-warning">
                <i class="bi bi-pencil-square"></i> Sửa
            </a>
            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
</div>