@model QLPhongGym.Models.ThanhToan

@{
    ViewData["Title"] = "Xóa thanh toán";
}

<div class="card shadow border-0 rounded-4">
    <div class="card-header bg-danger text-white py-3 rounded-top-4">
        <h4 class="mb-0">
            <i class="bi bi-trash3-fill"></i> Xóa phiếu thanh toán
        </h4>
    </div>

    <div class="card-body p-4">
        <div class="alert alert-warning d-flex align-items-center rounded-3">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
            <div>Bạn có chắc chắn muốn xóa phiếu thanh toán này không?</div>
        </div>

        <table class="table table-bordered align-middle">
            <tr>
                <th width="220" class="bg-light">Mã thanh toán</th>
                <td>@Model.MaThanhToan</td>
            </tr>
            <tr>
                <th class="bg-light">Hội viên</th>
                <td>@Model.DangKyGoiTap?.HoiVien?.HoTen</td>
            </tr>
            <tr>
                <th class="bg-light">Gói tập</th>
                <td>@Model.DangKyGoiTap?.GoiTap?.TenGoiTap</td>
            </tr>
            <tr>
                <th class="bg-light">Ngày thanh toán</th>
                <td>@Model.NgayThanhToan.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            <tr>
                <th class="bg-light">Số tiền</th>
                <td class="text-danger fw-bold">@Model.SoTien.ToString("N0") VNĐ</td>
            </tr>
            <tr>
                <th class="bg-light">Phương thức</th>
                <td>@Model.PhuongThuc</td>
            </tr>
            <tr>
                <th class="bg-light">Ghi chú</th>
                <td>@Model.GhiChu</td>
            </tr>
        </table>

        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" asp-for="MaThanhToan" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash3"></i> Xác nhận xóa
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="bi bi-arrow-left"></i> Hủy
            </a>
        </form>
    </div>
</div>